APP_ENV=production
DEFAULT_BOT_KEY=razaltush
TELEGRAM_BOTS__0__KEY=razaltush
TELEGRAM_BOTS__0__TOKEN=<razaltush-telegram-bot-token>
TELEGRAM_BOTS__0__EXPECTED_USERNAME=RazaltushVpnBot
PUBLIC_TELEGRAM_BOT_USERNAME=@RazaltushVpnBot
ADMIN_TELEGRAM_IDS=<admin-telegram-id>
SUPPORT_AGENT_TELEGRAM_IDS=<support-agent-telegram-id>

DATABASE_URL=sqlite+aiosqlite:////var/lib/vpn-access-bot/vpn_bot.db
INSTANCE_LOCK_PATH=/var/lib/vpn-access-bot/vpn-access-bot.lock
LOG_DIRECTORY=/var/log/vpn-access-bot

MEDIATOR_BASE_URL=http://127.0.0.1:5062
MEDIATOR_ADMIN_TOKEN=<at-least-32-random-characters>
PUBLIC_SUBSCRIPTION_BASE_URL=https://vpn.example

PAYMENT_MODE=telegram_stars
YOOKASSA_INTEGRATION_ENABLED=false
EXTERNAL_PAYMENT_ENABLED=false
PRICING_VERSION=closed-beta-2026-06-v2
PRICING_BASE_DEVICE_MONTH_STARS=60
PRICING_BASE_DEVICE_MONTH_RUB_KOPECKS=19900
PRICING_DURATION_DISCOUNTS=1:0,3:10,6:20,12:30

# Populate all values below before enabling the integration. To stop new SBP sales while
# retaining webhook recovery, keep YOOKASSA_INTEGRATION_ENABLED=true and set
# EXTERNAL_PAYMENT_ENABLED=false.
CHECKOUT_PUBLIC_BASE_URL=https://pay.vpn.example
CHECKOUT_BIND_HOST=127.0.0.1
CHECKOUT_BIND_PORT=8082
CHECKOUT_TOKEN_SECRET=<at-least-32-random-characters>
YOOKASSA_SHOP_ID=<yookassa-shop-id>
YOOKASSA_SECRET_KEY=<yookassa-secret-key>
YOOKASSA_RETURN_URL=https://pay.vpn.example/payment/return
YOOKASSA_WEBHOOK_PATH_SECRET=<at-least-24-random-characters>
TRIAL_ENABLED=false
REFERRAL_ENABLED=false

SUPPORT_CHAT_ID=<support-chat-id>
SUPPORT_CONTACT=<real-support-contact>
