ASPNETCORE_URLS=http://127.0.0.1:5062
ASPNETCORE_ENVIRONMENT=Production

VpnMediator__SqliteDatabasePath=/var/lib/vpn-mediator/vpn-mediator.db
VpnMediator__PublicBaseUrl=https://vpn.example
VpnMediator__SupportTelegramBotUsername=@RazaltushVpnBot
VpnMediator__AdminToken=<at-least-32-random-characters>
VpnMediator__DeviceTokenHashKey=<independent-at-least-32-random-characters>

VpnMediator__DeviceCredentialProtectionKeyId=v1
VpnMediator__DeviceCredentialProtectionKey=<base64-32-byte-key>
VpnMediator__SourceEndpointProtectionKeyId=v1
VpnMediator__SourceEndpointProtectionKey=<different-base64-32-byte-key>
VpnMediator__DeviceIdentityHashKeyId=v1
VpnMediator__DeviceIdentityHashKey=<different-at-least-32-random-characters>

VpnMediator__AllowDevelopmentHttpSources=false
VpnMediator__AllowLegacySubscriptionLinks=false

# Set previous key ID/key pairs only during a controlled key rotation.
# VpnMediator__PreviousDeviceCredentialProtectionKeyId=v0
# VpnMediator__PreviousDeviceCredentialProtectionKey=<old-base64-32-byte-key>
# VpnMediator__PreviousSourceEndpointProtectionKeyId=v0
# VpnMediator__PreviousSourceEndpointProtectionKey=<old-base64-32-byte-key>
# VpnMediator__PreviousDeviceIdentityHashKeyId=v0
# VpnMediator__PreviousDeviceIdentityHashKey=<old-random-key>

# Optional capacity gates. Zero means no configured capacity ceiling.
VpnMediator__ConfiguredSubscriptionCapacity=0
VpnMediator__ConfiguredDeviceCapacity=0

# Optional presentation mapping by stable source number.
# VpnMediator__ServerPresentationCountryBySourceNumber__4=Германия
