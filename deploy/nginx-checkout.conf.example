# This directive belongs in the nginx http {} block.
limit_req_zone $binary_remote_addr zone=vpn_checkout:10m rate=30r/m;

server {
    listen 443 ssl http2;
    server_name pay.vpn.example;

    # TLS certificate directives are deployment-specific.
    client_max_body_size 32k;

    location /checkout/ {
        limit_req zone=vpn_checkout burst=15 nodelay;
        access_log off;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        proxy_pass http://127.0.0.1:8082;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $remote_addr;
    }

    location /payment/ {
        limit_req zone=vpn_checkout burst=15 nodelay;
        access_log off;
        proxy_no_cache 1;
        proxy_pass http://127.0.0.1:8082;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
    }

    location /webhooks/yookassa/ {
        access_log off;
        proxy_no_cache 1;
        proxy_pass http://127.0.0.1:8082;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $remote_addr;
    }

    location / {
        return 404;
    }
}
