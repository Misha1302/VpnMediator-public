    "SqliteDatabasePath": "data/vpn-mediator.db",
    "DefaultMaxDevices": 3,
    "PublicBaseUrl": null,
    "LinkSigningSecret": "",
    "DeviceTokenHashKey": "",
    "AdminToken": "",
    "PreviousAdminToken": null,
