    "PreviousAdminTokenValidUntilUtc": null,
    "SourceEndpointProtectionKeyId": "v1",
    "PreviousSourceEndpointProtectionKeyId": null,
    "PreviousSourceEndpointProtectionKey": null,
    "CriticalWorkerConsecutiveFailureLimit": 5,
    "ServerCatalogMaxLinksPerSourceRead": 5000,
    "ConfiguredSubscriptionCapacity": 0,
